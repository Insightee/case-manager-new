# Railway API service — paste into Project → Service (backend) → Variables
# Project ID: b5944bdb-23e6-4d32-bf7e-f2eeb9494ca4
# Do NOT set SMTP on Vercel. Set VITE_API_URL on Vercel only (see frontend/vercel-env.example).

APP_ENV=production
SEED_DEMO_DATA=false

# Reference the Postgres plugin (Railway variable reference syntax):
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}

JWT_SECRET_KEY=<long-random-string>
JWT_REFRESH_SECRET_KEY=<different-long-random-string>

# Vercel frontend URL (no trailing slash) — must match CORS entry below
FRONTEND_URL=https://frontend-omega-eight-92.vercel.app
CORS_ORIGINS=http://localhost:5173,https://frontend-omega-eight-92.vercel.app

# ZeptoMail SMTP (API only)
EMAIL_PROVIDER=zeptomail
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASSWORD=<zeptomail-send-token-secret>
SMTP_TLS=true
SMTP_FROM_EMAIL=noreply@insighte.in
SMTP_FROM_BILLING_EMAIL=billing.noreply@insighte.in
SMTP_FROM_VERIFICATION_EMAIL=verification.noreply@insighte.in
SMTP_FROM_NAME=Insighte

PASSWORD_RESET_EXPIRE_HOURS=1
PASSWORD_RESET_RATE_LIMIT_PER_HOUR=3

STORAGE_PROVIDER=r2
STORAGE_PREFIX=insightcase
STORAGE_ENVIRONMENT=production
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
