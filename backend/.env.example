APP_ENV=development
# Set to production on Railway; triggers JWT/CORS/storage/Postgres guards at API startup
SEED_DEMO_DATA=false
# Only true for local demos or dedicated staging — never on shared production

DATABASE_URL=postgresql+psycopg2://insightcase:insightcase@localhost:5432/insightcase
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-production
JWT_REFRESH_SECRET_KEY=change-me-refresh-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# For Vercel previews, add each preview URL (comma-separated), e.g.:
# CORS_ORIGINS=http://localhost:5173,https://insightcase.vercel.app,https://insightcase-git-main-yourteam.vercel.app
FRONTEND_URL=http://localhost:5173
# Used in invite links, password reset emails, and booking notifications — must match your Vercel URL in production.

# Optional: external policies clarification bot (support ticket pages)
POLICIES_BOT_URL=

# Transactional email (ZeptoMail SMTP recommended for production).
# When SMTP_HOST is unset, emails are logged only (safe for local dev).
EMAIL_PROVIDER=zeptomail
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@insighte.in
SMTP_FROM_BILLING_EMAIL=billing.noreply@insighte.in
SMTP_FROM_VERIFICATION_EMAIL=verification.noreply@insighte.in
SMTP_FROM_NAME=Insighte
# Optional legacy full From header (overrides SMTP_FROM_EMAIL + SMTP_FROM_NAME when set):
# SMTP_FROM=Insighte <noreply@insighte.in>
SMTP_TLS=true
# Comma-separated admin inboxes for walk-in summaries and some scheduling alerts
ADMIN_NOTIFICATION_EMAILS=

# Password reset link lifetime (hours)
PASSWORD_RESET_EXPIRE_HOURS=1
# Max forgot-password requests per email per hour (abuse limit)
PASSWORD_RESET_RATE_LIMIT_PER_HOUR=3

# Report image storage (local dev default; use r2 in production)
STORAGE_PROVIDER=local
STORAGE_PREFIX=insightcase
STORAGE_ENVIRONMENT=development
MAX_UPLOAD_BYTES=10485760
# R2 (required when STORAGE_PROVIDER=r2 — bucket must stay private)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
