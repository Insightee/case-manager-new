APP_ENV=development
# Set to production on Railway; triggers JWT/CORS/storage/Postgres guards at API startup
SEED_DEMO_DATA=false
# Only true for local demos or dedicated staging — never on shared production

DATABASE_URL=postgresql+psycopg2://insightcase:insightcase@localhost:5432/insightcase
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-production
JWT_REFRESH_SECRET_KEY=change-me-refresh-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# For Vercel previews, add each preview URL (comma-separated), e.g.:
# CORS_ORIGINS=http://localhost:5173,https://insightcase.vercel.app,https://insightcase-git-main-yourteam.vercel.app
FRONTEND_URL=http://localhost:5173
# Optional: external policies clarification bot (support ticket pages)
POLICIES_BOT_URL=

# SMTP (optional — booking/leave/invite emails log-only when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=InsightCase <noreply@insighte.com>
SMTP_TLS=true
# Comma-separated in-app admin targets for walk-in summaries (also used by email layer when configured)
ADMIN_NOTIFICATION_EMAILS=

# Report image storage (local dev default; use r2 in production)
STORAGE_PROVIDER=local
STORAGE_PREFIX=insightcase
STORAGE_ENVIRONMENT=development
MAX_UPLOAD_BYTES=10485760
# R2 (required when STORAGE_PROVIDER=r2 — bucket must stay private)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
