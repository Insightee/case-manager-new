# Leave empty in local dev so Vite proxies /api → http://localhost:8000 (recommended).
# Local: leave empty to use Vite proxy to :8000, or set explicitly:
# VITE_API_URL=http://localhost:8000
# Vercel preview: set to your public API (no trailing slash), e.g. https://api.example.com
VITE_API_URL=
# Optional fallback if /api/v1/support/info has no policies_bot_url
VITE_POLICIES_BOT_URL=
